# Copy this file to .vmui-vm.env and fill the machine-specific values.

VMUI_VM_HOST=192.168.32.142
VMUI_VM_SSH_PORT=22
VMUI_VM_SSH_USER=

# Optional: use an SSH config alias instead of VMUI_VM_HOST / VMUI_VM_SSH_USER.
# VMUI_VM_SSH_TARGET=vmui-win

# Optional: explicit SSH config and identity file.
# VMUI_VM_SSH_CONFIG_FILE=/home/egor/.ssh/config
# VMUI_VM_SSH_IDENTITY_FILE=/home/egor/.ssh/id_ed25519

VMUI_VM_WORKDIR=C:/vmui-agent
# Optional after PowerShell 7 bootstrap:
# VMUI_VM_POWERSHELL_EXE=pwsh.exe
VMUI_VM_DAEMON_HOST=127.0.0.1
VMUI_VM_DAEMON_PORT=50051
VMUI_VM_LOCAL_FORWARD_PORT=50051
VMUI_VM_SESSION_TASK=vmui-agent-session
VMUI_VM_SMOKE_TASK=vmui-smoke
VMUI_VM_ARTIFACT_DIR=C:/vmui-agent/var/artifacts
VMUI_VM_LOG_DIR=C:/vmui-agent/var/log
